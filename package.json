{
  "name": "movie-recommendation-miniapp",
  "version": "1.0.0",
  "description": "基于标签匹配的高分影视推荐+AI趣味影评小程序",
  "main": "index.js",
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "postinstall": "Remove-Item -Path 'node_modules/@tarojs/webpack5-runner/node_modules/babel-loader' -Recurse -Force -ErrorAction SilentlyContinue"
  },
  "dependencies": {
    "@tarojs/components": "^4.2.0",
    "@tarojs/helper": "^4.1.9",
    "@tarojs/plugin-framework-react": "^4.2.0",
    "@tarojs/plugin-platform-alipay": "^4.1.9",
    "@tarojs/plugin-platform-h5": "^4.1.9",
    "@tarojs/plugin-platform-tt": "^4.1.9",
    "@tarojs/plugin-platform-weapp": "^4.2.0",
    "@tarojs/react": "^4.2.0",
    "@tarojs/runtime": "^4.1.9",
    "@tarojs/shared": "^4.1.9",
    "@tarojs/taro": "^4.2.0",
    "classnames": "^2.5.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@babel/preset-typescript": "^7.24.7",
    "@tarojs/cli": "^4.2.0",
    "@tarojs/webpack5-runner": "^4.2.0",
    "@types/react": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "ajv": "^8.20.0",
    "ajv-keywords": "^5.1.0",
    "babel-loader": "^9.2.1",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "sass": "^1.101.0",
    "typescript": "^5.1.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
